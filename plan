import os
import json
import logging
from datetime import datetime, time
from zoneinfo import ZoneInfo
from telegram import Update
from telegram.ext import (
    Application,
    CommandHandler,
    ContextTypes,
    MessageHandler,
    filters,
    ConversationHandler,
)
from apscheduler.schedulers.asyncio import AsyncIOScheduler
from dotenv import load_dotenv
load_dotenv()

from storage import load_tasks, save_tasks, load_stats, save_stats

logging.basicConfig(
    format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    level=logging.INFO,
)
logger = logging.getLogger(__name__)

TOKEN = os.getenv("BOT_TOKEN")
MY_CHAT_ID = int(os.getenv("MY_CHAT_ID"))
TIMEZONE = os.getenv("TIMEZONE", "Europe/Kiev")

WAITING_TASK = 1
WAITING_REMOVE = 2


def only_me(func):
    async def wrapper(update: Update, context: ContextTypes.DEFAULT_TYPE):
        if update.effective_user.id != MY_CHAT_ID:
            await update.message.reply_text("Доступ заборонено.")
            return
        return await func(update, context)
    return wrapper


@only_me
async def cmd_plan(update: Update, context: ContextTypes.DEFAULT_TYPE):
    tasks = load_tasks()
    if not tasks:
        await update.message.reply_text(
            "Список задач порожній.\n"
            "Додай задачу командою /add"
        )
        return

    lines = ["📋 *Твій план на сьогодні:*\n"]
    for i, t in enumerate(tasks, 1):
        status = "✅" if t.get("done") else "⬜"
        lines.append(f"{status} {i}. {t['text']}")

    done = sum(1 for t in tasks if t.get("done"))
    lines.append(f"\n_{done}/{len(tasks)} виконано_")
    await update.message.reply_text("\n".join(lines), parse_mode="Markdown")


@only_me
async def cmd_add(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.args:
        text = " ".join(context.args)
        tasks = load_tasks()
        tasks.append({"text": text, "done": False, "added": datetime.now().isoformat()})
        save_tasks(tasks)
        await update.message.reply_text(f"✅ Додано: *{text}*", parse_mode="Markdown")
        return

    await update.message.reply_text(
        "Напиши задачу, яку додати:\n_(або /cancel щоб скасувати)_",
        parse_mode="Markdown",
    )
    return WAITING_TASK


async def receive_task(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.strip()
    tasks = load_tasks()
    tasks.append({"text": text, "done": False, "added": datetime.now().isoformat()})
    save_tasks(tasks)
    await update.message.reply_text(f"✅ Додано: *{text}*", parse_mode="Markdown")
    return ConversationHandler.END


@only_me
async def cmd_remove(update: Update, context: ContextTypes.DEFAULT_TYPE):
    tasks = load_tasks()
    if not tasks:
        await update.message.reply_text("Список порожній.")
        return

    if context.args:
        try:
            idx = int(context.args[0]) - 1
            removed = tasks.pop(idx)
            save_tasks(tasks)
            await update.message.reply_text(
                f"🗑 Видалено: *{removed['text']}*", parse_mode="Markdown"
            )
            return
        except (ValueError, IndexError):
            await update.message.reply_text("Невірний номер. Перевір /plan")
            return

    lines = ["Який номер задачі видалити?\n"]
    for i, t in enumerate(tasks, 1):
        lines.append(f"{i}. {t['text']}")
    lines.append("\n_Відправ номер або /cancel_")
    await update.message.reply_text("\n".join(lines), parse_mode="Markdown")
    return WAITING_REMOVE


async def receive_remove(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        idx = int(update.message.text.strip()) - 1
        tasks = load_tasks()
        removed = tasks.pop(idx)
        save_tasks(tasks)
        await update.message.reply_text(
            f"🗑 Видалено: *{removed['text']}*", parse_mode="Markdown"
        )
    except (ValueError, IndexError):
        await update.message.reply_text("Невірний номер. Спробуй ще.")
    return ConversationHandler.END


@only_me
async def cmd_done(update: Update, context: ContextTypes.DEFAULT_TYPE):
    tasks = load_tasks()
    if not tasks:
        await update.message.reply_text("Список порожній.")
        return

    if not context.args:
        undone = [(i, t) for i, t in enumerate(tasks) if not t.get("done")]
        if not undone:
            await update.message.reply_text("Всі задачі вже виконані! ")
            return
        lines = ["Яку задачу відмітити виконаною?\n"]
        for i, t in undone:
            lines.append(f"{i+1}. {t['text']}")
        lines.append("\nВикористай: /done <номер>")
        await update.message.reply_text("\n".join(lines))
        return

    try:
        idx = int(context.args[0]) - 1
        if tasks[idx].get("done"):
            await update.message.reply_text("Ця задача вже виконана ✅")
            return
        tasks[idx]["done"] = True
        tasks[idx]["done_at"] = datetime.now().isoformat()
        save_tasks(tasks)

        stats = load_stats()
        today = datetime.now().strftime("%Y-%m-%d")
        stats[today] = stats.get(today, 0) + 1
        save_stats(stats)

        await update.message.reply_text(
            f"✅ Виконано: *{tasks[idx]['text']}*", parse_mode="Markdown"
        )
    except (ValueError, IndexError):
        await update.message.reply_text("Невірний номер. Перевір /plan")


@only_me
async def cmd_stats(update: Update, context: ContextTypes.DEFAULT_TYPE):
    stats = load_stats()
    if not stats:
        await update.message.reply_text("Ще немає статистики. Починай виконувати задачі!")
        return

    sorted_days = sorted(stats.keys())[-7:]
    lines = ["📊 *Статистика за 7 днів:*\n"]
    total = 0
    for day in sorted_days:
        count = stats[day]
        total += count
        bar = "▓" * count + "░" * max(0, 5 - count)
        lines.append(f"`{day}` {bar} {count}")

    lines.append(f"\nВсього виконано: *{total}* задач")
    await update.message.reply_text("\n".join(lines), parse_mode="Markdown")


@only_me
async def cmd_reset(update: Update, context: ContextTypes.DEFAULT_TYPE):
    tasks = load_tasks()
    for t in tasks:
        t["done"] = False
        t.pop("done_at", None)
    save_tasks(tasks)
    await update.message.reply_text("🔄 Всі задачі скинуті до невиконаних.")


@only_me
async def cmd_clear(update: Update, context: ContextTypes.DEFAULT_TYPE):
    save_tasks([])
    await update.message.reply_text("🗑 Список очищено повністю.")


async def cmd_cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Скасовано.")
    return ConversationHandler.END


async def send_daily_plan(context: ContextTypes.DEFAULT_TYPE):
    tasks = load_tasks()
    for t in tasks:
        t["done"] = False
        t.pop("done_at", None)
    save_tasks(tasks)

    if not tasks:
        await context.bot.send_message(
            chat_id=MY_CHAT_ID,
            text="☀️ Доброго ранку! Список задач порожній. Додай щось командою /add",
        )
        return

    lines = ["☀️ *Доброго ранку! Ось твій план на сьогодні:*\n"]
    for i, t in enumerate(tasks, 1):
        lines.append(f"⬜ {i}. {t['text']}")
    lines.append(f"\n_Всього задач: {len(tasks)}_")
    await context.bot.send_message(
        chat_id=MY_CHAT_ID,
        text="\n".join(lines),
        parse_mode="Markdown",
    )


async def post_init(application: Application):
    tz = ZoneInfo(TIMEZONE)
    scheduler = AsyncIOScheduler(timezone=tz)
    scheduler.add_job(
        send_daily_plan,
        trigger="cron",
        hour=9,
        minute=0,
        args=[application],
    )
    scheduler.start()
    application.bot_data["scheduler"] = scheduler
    logger.info("Scheduler started — daily plan at 09:00 %s", TIMEZONE)


def main():
    app = Application.builder().token(TOKEN).post_init(post_init).build()

    conv_add = ConversationHandler(
        entry_points=[CommandHandler("add", cmd_add)],
        states={WAITING_TASK: [MessageHandler(filters.TEXT & ~filters.COMMAND, receive_task)]},
        fallbacks=[CommandHandler("cancel", cmd_cancel)],
    )

    conv_remove = ConversationHandler(
        entry_points=[CommandHandler("remove", cmd_remove)],
        states={WAITING_REMOVE: [MessageHandler(filters.TEXT & ~filters.COMMAND, receive_remove)]},
        fallbacks=[CommandHandler("cancel", cmd_cancel)],
    )

    app.add_handler(CommandHandler("plan", cmd_plan))
    app.add_handler(CommandHandler("done", cmd_done))
    app.add_handler(CommandHandler("stats", cmd_stats))
    app.add_handler(CommandHandler("reset", cmd_reset))
    app.add_handler(CommandHandler("clear", cmd_clear))
    app.add_handler(conv_add)
    app.add_handler(conv_remove)

    logger.info("Bot started")
    app.run_polling(drop_pending_updates=True)


if __name__ == "__main__":
    main()